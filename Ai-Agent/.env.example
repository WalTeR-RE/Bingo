# Copy this file to .env and fill in your keys.
# OpenAI key used by every agent role (gpt-4o-mini, Whisper, TTS, embeddings).
OPENAI_API_KEY=sk-your-openai-key

# Dashboard access token used to submit reports/incidents to the Laravel API.
# Create it in the dashboard (Settings -> API tokens); it starts with bingo_ak_.
REPORTING_API_KEY=bingo_ak_your-dashboard-access-token

# Optional: override the reporting endpoint (defaults to http://localhost:8000/api).
# REPORTING_API_URL=http://localhost:8000/api
